generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            Int      @id @default(autoincrement())
  username      String   @unique
  password_hash String
  is_approved   Boolean  @default(false)
  is_admin      Boolean  @default(false)
  is_banned     Boolean  @default(false)
  created_at    DateTime @default(now())
}

model Node {
  id         String   @id // Hex Node ID (e.g. "a0352680")
  long_name  String?
  short_name String?
  last_heard DateTime @default(now())
  updated_at DateTime @updatedAt
}

model Squawk {
  id              Int      @id @default(autoincrement())
  author          String
  node_id         String
  message         String
  is_global       Boolean  @default(false)
  reply_to_id     Int?
  parent_squawk   Squawk?  @relation("SquawkReplies", fields: [reply_to_id], references: [id])
  child_squawks   Squawk[] @relation("SquawkReplies")
  mesh_packet_id  String?  // Native Meshtastic packet ID for threading

  // Real Telemetry Data
  snr            Float?
  rssi           Int?
  hops           Int?
  
  created_at     DateTime @default(now())
}

model Setting {
  key   String @id
  value String
}

model Connection {
  id         String   @id
  status     String
  updated_at DateTime @updatedAt
}
